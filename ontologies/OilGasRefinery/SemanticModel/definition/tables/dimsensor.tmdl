table dimsensor
	lineageTag: 10000008-0001-0001-0001-000000000001

	measure 'Sensor Count' = COUNTROWS(dimsensor)
		displayFolder: Measures
		lineageTag: 10000008-0001-0001-0001-100000000001

	measure 'Active Sensor Count' = CALCULATE(COUNTROWS(dimsensor), dimsensor[Status] = "Active")
		displayFolder: Measures
		lineageTag: 10000008-0001-0001-0001-100000000002

